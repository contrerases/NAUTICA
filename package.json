{
  "name": "nautica-jornada",
  "version": "0.1.0",
  "description": "Sistema de control de jornada laboral para Náutica Botes Inflables SpA",
  "main": "./out/main/index.js",
  "author": "Náutica Botes Inflables SpA",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "package": "npm run build && electron-builder --win --config",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "12.8.0",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.19",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.17",
    "electron": "34.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "pinia": "^2.1.7",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "vue": "^3.4.19",
    "vue-router": "^4.2.5",
    "vue-tsc": "^2.0.9"
  },
  "build": {
    "appId": "com.nautica.jornada",
    "productName": "Náutica Jornada",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "database",
        "to": "database",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Náutica Jornada"
    }
  }
}
